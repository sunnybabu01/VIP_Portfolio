# Server Configuration
PORT=5000
NODE_ENV=development
JWT_SECRET=super_secret_jwt_token_for_sunny_ranjan_portfolio
SESSION_SECRET=another_super_secret_session_key

# Database Configuration
# Replace with your local MongoDB URI or MongoDB Atlas URI
MONGODB_URI=mongodb://127.0.0.1:27017/vip_portfolio

# Admin Credentials (Used by seed script to initialize admin)
ADMIN_USERNAME=admin
ADMIN_EMAIL=sunnyranjan@example.com
ADMIN_PASSWORD=AdminPassword123

# Cloudinary Configuration (Optional, local storage fallback if empty)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Nodemailer Configuration (Optional, console logging fallback if empty)
# Use Gmail SMTP or other provider settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=585
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
CONTACT_RECEIVER_EMAIL=sunnyranjan@example.com

# Gemini AI API Configuration
# Get your API key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key
