<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>404 - Page Not Found | Sunny Ranjan</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class'
    }
  </script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="h-full bg-slate-50 dark:bg-slate-950 text-slate-800 dark:text-slate-100 transition-colors duration-300 flex items-center justify-center relative overflow-hidden">
  
  <!-- Glowing blobs background -->
  <div class="absolute top-1/4 left-1/4 w-80 h-80 rounded-full bg-blue-500/10 dark:bg-blue-500/5 glow-circle"></div>
  <div class="absolute bottom-1/4 right-1/4 w-80 h-80 rounded-full bg-purple-500/10 dark:bg-purple-500/5 glow-circle"></div>

  <!-- 404 Container -->
  <div class="max-w-md w-full px-6 text-center z-10">
    <div class="glass dark:glass p-8 sm:p-12 rounded-3xl shadow-2xl relative border border-slate-200/50 dark:border-slate-800/50">
      
      <!-- Icon -->
      <div class="w-20 h-20 mx-auto rounded-full bg-red-100 dark:bg-red-950/30 flex items-center justify-center text-red-500 dark:text-red-400 mb-6">
        <i class="fas fa-exclamation-triangle text-3xl animate-bounce"></i>
      </div>

      <!-- Heading -->
      <h1 class="font-heading font-extrabold text-7xl sm:text-8xl text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-purple-600 dark:from-blue-400 dark:to-purple-400 tracking-tight">404</h1>
      <h2 class="font-heading font-bold text-xl sm:text-2xl mt-4 text-slate-800 dark:text-white">Page Not Found</h2>
      
      <!-- Subtext -->
      <p class="text-sm sm:text-base text-slate-500 dark:text-slate-400 mt-3 mb-8 leading-relaxed">
        The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.
      </p>

      <!-- Action -->
      <a href="/" class="inline-flex items-center justify-center bg-blue-600 hover:bg-blue-700 text-white font-semibold text-sm px-6 py-3 rounded-full shadow-lg shadow-blue-500/25 active:scale-95 transition-all">
        <i class="fas fa-arrow-left mr-2.5"></i>
        Back to Portfolio
      </a>

    </div>
  </div>

  <script>
    // Sync dark/light class with client storage
    const currentTheme = localStorage.getItem('color-theme') || 
      (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    if (currentTheme === 'dark') {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  </script>
</body>
</html>
