  </main>

  <!-- Public Footer Section -->
  <footer class="bg-white border-t border-slate-200 dark:bg-slate-900 dark:border-slate-800 transition-colors py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center border-b border-slate-100 dark:border-slate-800/50 pb-8 mb-8 text-center md:text-left">
        
        <!-- Column 1: Brand -->
        <div>
          <h3 class="font-heading font-extrabold text-lg text-slate-800 dark:text-white">Sunny Ranjan</h3>
          <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Software Developer | B.Tech CSIT (2023-2027)</p>
        </div>

        <!-- Column 2: Quick Links -->
        <div class="flex flex-wrap justify-center space-x-6 text-sm font-semibold text-slate-500 dark:text-slate-400">
          <a href="/#about" class="hover:text-blue-600 dark:hover:text-blue-400">About</a>
          <a href="/#projects" class="hover:text-blue-600 dark:hover:text-blue-400">Projects</a>
          <a href="/blogs" class="hover:text-blue-600 dark:hover:text-blue-400">Blogs</a>
          <a href="/gallery" class="hover:text-blue-600 dark:hover:text-blue-400">Gallery</a>
          <a href="/admin/login" class="hover:text-blue-600 dark:hover:text-blue-400"><i class="fas fa-lock mr-1.5"></i>CMS Panel</a>
        </div>

        <!-- Column 3: Social Icons -->
        <div class="flex justify-center md:justify-end space-x-4">
          <% if (typeof profile !== 'undefined' && profile.socialLinks) { %>
            <% if (profile.socialLinks.github) { %>
              <a href="<%= profile.socialLinks.github %>" target="_blank" class="w-10 h-10 rounded-full bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 flex items-center justify-center text-slate-700 dark:text-slate-300 hover:text-blue-600 transition-colors"><i class="fab fa-github text-lg"></i></a>
            <% } %>
            <% if (profile.socialLinks.linkedin) { %>
              <a href="<%= profile.socialLinks.linkedin %>" target="_blank" class="w-10 h-10 rounded-full bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 flex items-center justify-center text-slate-700 dark:text-slate-300 hover:text-blue-600 transition-colors"><i class="fab fa-linkedin-in text-lg"></i></a>
            <% } %>
            <% if (profile.socialLinks.leetcode) { %>
              <a href="<%= profile.socialLinks.leetcode %>" target="_blank" class="w-10 h-10 rounded-full bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 flex items-center justify-center text-slate-700 dark:text-slate-300 hover:text-blue-600 transition-colors"><i class="fas fa-code text-base"></i></a>
            <% } %>
          <% } %>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row justify-between items-center text-xs text-slate-400 dark:text-slate-500">
        <p>&copy; <%= new Date().getFullYear() %> Sunny Ranjan. All rights reserved.</p>
        <p class="mt-2 sm:mt-0 flex items-center space-x-1.5">
          <span>Crafted with EJS & Express</span>
          <span class="w-1 h-1 bg-slate-300 dark:bg-slate-700 rounded-full"></span>
          <span>SEO Optimized</span>
        </p>
      </div>
    </div>
  </footer>

  <!-- ==========================================
  # "ASK SUNNY" AI CHATBOT FLOAT PANEL
  ========================================== -->
  <div class="fixed bottom-6 right-6 z-50 flex flex-col items-end">
    
    <!-- Chat Window Container -->
    <div id="chatbot-window" class="hidden w-[350px] sm:w-[380px] h-[500px] bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl shadow-2xl flex-col overflow-hidden mb-4 animate-fade-in-up">
      
      <!-- Chat Header -->
      <div class="bg-gradient-to-r from-blue-600 to-purple-600 p-4 text-white flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <div class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center border border-white/20">
            <i class="fas fa-robot text-base"></i>
          </div>
          <div>
            <h4 class="font-heading font-bold text-sm">Ask Sunny</h4>
            <p class="text-[11px] text-blue-100 flex items-center">
              <span class="w-1.5 h-1.5 bg-green-400 rounded-full mr-1.5 animate-pulse"></span>
              Gemini AI Twin
            </p>
          </div>
        </div>
        <button id="chatbot-close" class="text-white/80 hover:text-white transition-colors p-1">
          <i class="fas fa-times text-lg"></i>
        </button>
      </div>

      <!-- Messages Window -->
      <div id="chatbot-messages" class="flex-grow p-4 overflow-y-auto space-y-3 scrollbar-thin">
        
        <!-- Welcome Message -->
        <div class="flex justify-start">
          <div class="flex items-start max-w-[85%]">
            <div class="w-8 h-8 rounded-full bg-gradient-to-tr from-blue-600 to-purple-600 flex items-center justify-center text-white text-xs mr-2 flex-shrink-0 font-heading">S</div>
            <div class="bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-100 text-sm rounded-2xl rounded-tl-none px-4 py-2 border border-gray-200/50 dark:border-gray-700/50 leading-relaxed shadow-sm">
              <p class="font-semibold text-xs text-blue-600 dark:text-blue-400 mb-1">AI Assistant</p>
              Hi there! I am **Ask Sunny**, Sunny Ranjan's digital assistant powered by Gemini. Ask me about his coding skills, B.Tech education, internships, SIH hackathon projects, or certifications!
            </div>
          </div>
        </div>
      </div>

      <!-- suggestion chips panel -->
      <div class="px-4 py-2 bg-slate-50 dark:bg-slate-950 border-t border-slate-100 dark:border-slate-800/50 flex space-x-2 overflow-x-auto whitespace-nowrap scrollbar-none">
        <button class="chatbot-chip bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-300 text-xs px-3 py-1.5 rounded-full hover:border-blue-500 hover:text-blue-600 transition-colors" data-query="What is Sunny's B.Tech degree?">Education</button>
        <button class="chatbot-chip bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-300 text-xs px-3 py-1.5 rounded-full hover:border-blue-500 hover:text-blue-600 transition-colors" data-query="Tell me about the Crypto Detection SIH Project.">SIH Project</button>
        <button class="chatbot-chip bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-300 text-xs px-3 py-1.5 rounded-full hover:border-blue-500 hover:text-blue-600 transition-colors" data-query="What achievements does Sunny have?">Achievements</button>
        <button class="chatbot-chip bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-300 text-xs px-3 py-1.5 rounded-full hover:border-blue-500 hover:text-blue-600 transition-colors" data-query="Show me Sunny's skills list.">Skills</button>
      </div>

      <!-- Chat input form -->
      <form id="chatbot-form" class="p-3 bg-white dark:bg-slate-900 border-t border-slate-200 dark:border-slate-800 flex items-center space-x-2">
        <input type="text" id="chatbot-input" placeholder="Type a message..." class="flex-grow text-sm px-4 py-2.5 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-800 dark:text-slate-100 border-none focus:ring-2 focus:ring-blue-500 focus:outline-none" required autocomplete="off">
        <button type="submit" class="w-10 h-10 rounded-full bg-blue-600 hover:bg-blue-700 text-white flex items-center justify-center shadow-lg shadow-blue-500/20 active:scale-95 transition-all">
          <i class="fas fa-paper-plane text-sm"></i>
        </button>
      </form>
    </div>

    <!-- Floating Trigger Bubble -->
    <button id="chatbot-toggle" class="w-14 h-14 rounded-full bg-gradient-to-tr from-blue-600 to-purple-600 text-white flex items-center justify-center shadow-2xl hover:scale-105 active:scale-95 transition-all duration-300 relative border border-white/10 group">
      <i class="fas fa-comments text-2xl group-hover:rotate-6 transition-transform"></i>
      <span class="absolute -top-1 -right-1 w-4 h-4 bg-green-500 border-2 border-white dark:border-slate-950 rounded-full"></span>
    </button>
  </div>

  <!-- Scripts connections -->
  <script src="/js/main.js"></script>
  <script src="/js/chatbot.js"></script>
</body>
</html>
