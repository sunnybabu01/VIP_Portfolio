<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-50 dark:bg-gray-950">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard | Portfolio CMS</title>
  
  <!-- CSS & Tailwind Inclusions -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'sans-serif'],
            heading: ['Outfit', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/png" href="/images/favicon.png?v=1.1">
</head>
<body class="h-full font-sans antialiased text-gray-800 dark:text-gray-100 transition-colors duration-200">

  <div class="min-h-full flex flex-col md:flex-row">
    
    <!-- Left Sidebar - Desktop -->
    <aside class="hidden md:flex flex-col w-64 bg-white dark:bg-gray-900 border-r border-gray-200 dark:border-gray-800/80 flex-shrink-0">
      <div class="h-16 flex items-center px-6 border-b border-gray-100 dark:border-gray-800/80">
        <a href="/admin/dashboard" class="flex items-center space-x-2 font-heading font-extrabold text-lg text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-purple-600 dark:from-blue-400 dark:to-purple-400">
          <i class="fas fa-sliders-h"></i>
          <span>Sunny.CMS</span>
        </a>
      </div>

      <!-- Navigation links -->
      <nav class="flex-grow p-4 space-y-1.5 overflow-y-auto">
        <% 
          const navItems = [
            { id: 'dashboard', name: 'Dashboard', icon: 'fas fa-chart-pie', link: '/admin/dashboard' },
            { id: 'profile', name: 'Profile & Bio', icon: 'fas fa-user-cog', link: '/admin/profile' },
            { id: 'skills', name: 'Skills & Levels', icon: 'fas fa-brain', link: '/admin/skills' },
            { id: 'projects', name: 'Projects DB', icon: 'fas fa-code-branch', link: '/admin/projects' },
            { id: 'experience', name: 'Experience', icon: 'fas fa-briefcase', link: '/admin/experience' },
            { id: 'certificates', name: 'Certifications', icon: 'fas fa-certificate', link: '/admin/certificates' },
            { id: 'achievements', name: 'Achievements', icon: 'fas fa-trophy', link: '/admin/achievements' },
            { id: 'blogs', name: 'Blog Manager', icon: 'fas fa-pen-nib', link: '/admin/blogs' },
            { id: 'gallery', name: 'Gallery DB', icon: 'fas fa-images', link: '/admin/gallery' },
            { id: 'testimonials', name: 'Testimonials', icon: 'fas fa-quote-left', link: '/admin/testimonials' },
            { id: 'messages', name: 'Messages Inbox', icon: 'fas fa-envelope', link: '/admin/messages' },
          ];
          const active = typeof activeTab !== 'undefined' ? activeTab : 'dashboard';
        %>
        
        <% navItems.forEach(item => { %>
          <a href="<%= item.link %>" class="flex items-center px-4 py-2.5 rounded-xl text-sm font-medium transition-all group <%= active === item.id ? 'bg-blue-600 text-white shadow-md shadow-blue-500/20' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800/50 hover:text-gray-950 dark:hover:text-white' %>">
            <i class="<%= item.icon %> w-5 h-5 flex items-center justify-center mr-3 <%= active === item.id ? 'text-white' : 'text-gray-400 dark:text-gray-500 group-hover:text-blue-500' %>"></i>
            <span><%= item.name %></span>
          </a>
        <% }) %>
      </nav>

      <!-- Sidebar footer -->
      <div class="p-4 border-t border-gray-100 dark:border-gray-800/80">
        <a href="/admin/logout" class="flex items-center px-4 py-2.5 rounded-xl text-sm font-semibold text-red-600 hover:bg-red-50 dark:hover:bg-red-950/20 transition-all">
          <i class="fas fa-sign-out-alt w-5 h-5 flex items-center justify-center mr-3"></i>
          Logout
        </a>
      </div>
    </aside>

    <!-- Mobile Header -->
    <header class="md:hidden bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800/80 px-4 py-3 flex items-center justify-between z-30">
      <a href="/admin/dashboard" class="font-heading font-extrabold text-lg text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-purple-600">
        Sunny.CMS
      </a>
      <div class="flex items-center space-x-3">
        <button onclick="document.getElementById('mobile-admin-sidebar').classList.toggle('hidden')" class="text-gray-600 dark:text-gray-300 p-2 focus:outline-none">
          <i class="fas fa-bars text-xl"></i>
        </button>
      </div>
    </header>

    <!-- Mobile Sidebar overlay -->
    <div id="mobile-admin-sidebar" class="hidden md:hidden fixed inset-0 z-40 bg-gray-900/60 flex justify-start">
      <div class="w-64 bg-white dark:bg-gray-900 h-full flex flex-col p-4 shadow-2xl relative">
        <button onclick="document.getElementById('mobile-admin-sidebar').classList.add('hidden')" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600">
          <i class="fas fa-times text-lg"></i>
        </button>
        <div class="font-heading font-extrabold text-lg mb-6 text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-purple-600">
          Sunny.CMS
        </div>
        <nav class="flex-grow space-y-1.5 overflow-y-auto">
          <% navItems.forEach(item => { %>
            <a href="<%= item.link %>" onclick="document.getElementById('mobile-admin-sidebar').classList.add('hidden')" class="flex items-center px-4 py-2.5 rounded-xl text-sm font-medium transition-all <%= active === item.id ? 'bg-blue-600 text-white' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800' %>">
              <i class="<%= item.icon %> w-5 h-5 flex items-center justify-center mr-3"></i>
              <span><%= item.name %></span>
            </a>
          <% }) %>
        </nav>
        <div class="border-t border-gray-100 dark:border-gray-800/80 pt-4">
          <a href="/admin/logout" class="flex items-center px-4 py-2.5 rounded-xl text-sm font-semibold text-red-600 hover:bg-red-50 transition-all">
            <i class="fas fa-sign-out-alt w-5 h-5 flex items-center justify-center mr-3"></i>
            Logout
          </a>
        </div>
      </div>
      <div onclick="document.getElementById('mobile-admin-sidebar').classList.add('hidden')" class="flex-grow"></div>
    </div>

    <!-- Main Workspace Area -->
    <div class="flex-grow flex flex-col min-w-0">
      
      <!-- Top header bar - Desktop -->
      <header class="hidden md:flex h-16 bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800/80 items-center justify-between px-8 flex-shrink-0">
        <div class="flex items-center space-x-1.5 text-xs text-gray-400 dark:text-gray-500 font-semibold uppercase tracking-wider">
          <span>CMS Panel</span>
          <i class="fas fa-chevron-right text-[9px]"></i>
          <span class="text-gray-800 dark:text-gray-200 capitalize"><%= active %></span>
        </div>

        <div class="flex items-center space-x-4">
          <!-- Light/Dark toggle in Admin -->
          <button onclick="document.getElementById('theme-toggle').click()" class="w-9 h-9 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-500 dark:text-gray-400 flex items-center justify-center">
            <i class="fas fa-circle-half-stroke"></i>
          </button>
          
          <!-- View Site Button -->
          <a href="/" target="_blank" class="flex items-center text-xs font-bold text-blue-600 dark:text-blue-400 border border-blue-200 dark:border-blue-800/80 px-4 py-2 rounded-lg hover:bg-blue-50 dark:hover:bg-blue-950/20 transition-all">
            <i class="fas fa-external-link-alt mr-2 text-[10px]"></i>
            View Portfolio
          </a>

          <!-- Profile Badge -->
          <div class="flex items-center space-x-3 pl-4 border-l border-gray-200 dark:border-gray-800/80">
            <div class="w-8 h-8 rounded-full bg-blue-100 dark:bg-blue-900 flex items-center justify-center font-bold text-blue-600 dark:text-blue-300 font-heading text-xs uppercase">
              <%= typeof profile !== 'undefined' && profile.name ? profile.name.substring(0, 2) : 'AD' %>
            </div>
            <div class="hidden xl:block">
              <h5 class="text-sm font-semibold leading-none"><%= typeof profile !== 'undefined' && profile.name ? profile.name : 'Administrator' %></h5>
              <span class="text-[10px] text-gray-400 font-medium leading-none mt-1 block">Role: Owner</span>
            </div>
          </div>
        </div>
      </header>

      <!-- CMS Main Content Container -->
      <main class="flex-grow p-4 sm:p-8 overflow-y-auto">
        
        <!-- Background light/dark toggle element mapped internally -->
        <button id="theme-toggle" class="hidden"></button>
        <span id="theme-toggle-light-icon" class="hidden"></span>
        <span id="theme-toggle-dark-icon" class="hidden"></span>
