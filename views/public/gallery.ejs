<%- include('../partials/header', { title: 'Photo Gallery', description: 'Explore project snapshots, certificates, and coding highlights in the photo gallery.' }) %>

<section class="py-16 sm:py-24 bg-slate-50 dark:bg-slate-950 transition-colors duration-300 relative min-h-[85vh] overflow-hidden">
  <!-- Interactive mesh gradient background -->
  <div class="absolute inset-0 mesh-gradient opacity-100 transition-colors duration-300"></div>

  <!-- Glowing neon circle elements -->
  <div class="absolute top-1/4 left-1/10 w-96 h-96 rounded-full bg-blue-500/10 dark:bg-blue-500/5 glow-circle"></div>
  <div class="absolute bottom-1/4 right-1/10 w-96 h-96 rounded-full bg-purple-500/10 dark:bg-purple-500/5 glow-circle"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10 relative">
    
    <!-- Section Heading -->
    <div class="text-center max-w-3xl mx-auto mb-16 animate-fade-in-up">
      <span class="text-xs font-bold uppercase tracking-wider text-blue-600 dark:text-blue-400">Visuals</span>
      <h1 class="font-heading font-extrabold text-3xl sm:text-5xl mt-2 text-slate-900 dark:text-white">Photo Gallery</h1>
      <div class="w-16 h-1.5 bg-blue-600 mx-auto mt-4 rounded-full"></div>
      <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400 mt-4 leading-relaxed font-normal">
        A curated showcase of project snapshots, technical diagrams, certificates, and developer milestones.
      </p>
    </div>

    <!-- Gallery Grid -->
    <% if (galleryItems && galleryItems.length > 0) { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <% galleryItems.forEach((item, index) => { %>
          <div class="project-card group bg-white dark:bg-slate-900 border border-slate-200/50 dark:border-slate-800/80 rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col h-full hover-card-3d cursor-pointer" onclick="openGalleryModal('<%= index %>')">
            
            <!-- Gallery Image -->
            <div class="relative aspect-[4/3] w-full overflow-hidden bg-slate-100 dark:bg-slate-950 flex-shrink-0 border-b border-slate-100 dark:border-slate-800/80">
              <img src="<%= item.imageUrl %>" alt="<%= item.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
              <div class="absolute inset-0 bg-slate-950/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                <div class="w-11 h-11 rounded-full bg-white/90 dark:bg-slate-900/90 flex items-center justify-center text-slate-800 dark:text-white shadow-md">
                  <i class="fas fa-expand-alt text-sm"></i>
                </div>
              </div>
            </div>

            <!-- Gallery Info -->
            <div class="p-5 flex-grow flex flex-col justify-between">
              <div>
                <h3 class="font-heading font-bold text-base text-slate-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors line-clamp-1"><%= item.title %></h3>
                <% if (item.description) { %>
                  <p class="text-xs text-slate-500 dark:text-slate-400 mt-2 line-clamp-2 leading-relaxed font-normal"><%= item.description %></p>
                <% } else { %>
                  <p class="text-xs text-slate-400 dark:text-slate-500 mt-2 italic font-normal">No description provided.</p>
                <% } %>
              </div>
              <div class="text-[10px] text-slate-400 font-bold uppercase mt-4 tracking-wider">
                Added: <%= new Date(item.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
              </div>
            </div>

          </div>

          <!-- Lightbox Modal for each item -->
          <div id="gallery-modal-<%= index %>" class="modal-container hidden fixed inset-0 z-50 bg-slate-950/80 p-4 sm:p-6 items-center justify-center animate-fade-in" onclick="closeGalleryModal(event, '<%= index %>')">
            <div class="bg-white dark:bg-slate-900 max-w-3xl w-full rounded-2xl shadow-2xl overflow-hidden flex flex-col max-h-[90vh] border border-slate-200 dark:border-slate-800" onclick="event.stopPropagation()">
              
              <!-- Modal Header -->
              <div class="p-4 sm:p-5 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between bg-slate-50 dark:bg-slate-950/30">
                <h3 class="font-heading font-extrabold text-sm sm:text-base text-slate-900 dark:text-white truncate pr-4"><%= item.title %></h3>
                <button onclick="hideGalleryModal('<%= index %>')" class="text-slate-400 hover:text-slate-600 dark:hover:text-white p-1 rounded-lg"><i class="fas fa-times text-lg"></i></button>
              </div>

              <!-- Modal Body -->
              <div class="p-6 overflow-y-auto space-y-6 flex flex-col items-center">
                <div class="rounded-xl overflow-hidden max-h-[50vh] bg-slate-100 dark:bg-slate-950 border border-slate-200/50 dark:border-slate-800/85">
                  <img src="<%= item.imageUrl %>" alt="<%= item.title %>" class="w-full h-full object-contain">
                </div>
                
                <% if (item.description) { %>
                  <div class="w-full text-center max-w-xl">
                    <p class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed font-normal"><%= item.description %></p>
                  </div>
                <% } %>
              </div>

              <!-- Modal Footer -->
              <div class="p-4 border-t border-slate-100 dark:border-slate-800/80 bg-slate-50 dark:bg-slate-950/30 flex justify-between items-center text-xs text-slate-400 dark:text-slate-500">
                <span>Upload date: <%= new Date(item.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></span>
                <a href="<%= item.imageUrl %>" target="_blank" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl transition-colors flex items-center shadow-lg shadow-blue-500/10">
                  <i class="fas fa-up-right-from-square mr-2 text-[10px]"></i> Open Original
                </a>
              </div>

            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="text-center py-20 bg-white dark:bg-slate-900 rounded-3xl border border-slate-200/50 dark:border-slate-800/80 shadow-sm max-w-3xl mx-auto">
        <i class="fas fa-images text-5xl text-slate-300 dark:text-slate-700 mb-4 block"></i>
        <p class="text-sm sm:text-base text-slate-500 font-semibold">The gallery is currently empty.</p>
        <p class="text-xs text-slate-400 mt-1">Check back later for updates or log in to the admin panel to add images.</p>
      </div>
    <% } %>

  </div>
</section>

<script>
  function openGalleryModal(index) {
    const modal = document.getElementById(`gallery-modal-${index}`);
    if (modal) {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }
  }

  function hideGalleryModal(index) {
    const modal = document.getElementById(`gallery-modal-${index}`);
    if (modal) {
      modal.classList.remove('flex');
      modal.classList.add('hidden');
      document.body.style.overflow = 'auto';
    }
  }

  function closeGalleryModal(event, index) {
    hideGalleryModal(index);
  }
</script>

<%- include('../partials/footer') %>
