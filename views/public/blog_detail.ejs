<%- include('../partials/header') %>

<section class="py-16 sm:py-24 bg-slate-50 dark:bg-slate-950 transition-colors duration-300 relative min-h-[85vh]">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Navigation Back Link -->
    <a href="/blogs" class="inline-flex items-center text-xs font-bold text-slate-500 hover:text-blue-600 transition-colors mb-8">
      <i class="fas fa-chevron-left mr-2 text-[9px]"></i>
      Back to Blogs
    </a>

    <!-- Blog Container -->
    <article class="bg-white dark:bg-slate-900 rounded-3xl overflow-hidden border border-slate-200/50 dark:border-slate-800/80 shadow-xl p-6 sm:p-10 space-y-8">
      
      <!-- Meta Details -->
      <div class="space-y-4">
        <span class="text-xs text-blue-600 dark:text-blue-400 font-bold"><%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></span>
        <h1 class="font-heading font-extrabold text-3xl sm:text-5xl text-slate-900 dark:text-white leading-tight tracking-tight"><%= blog.title %></h1>
        
        <div class="flex flex-wrap gap-2 pt-2">
          <% blog.tags.forEach(tag => { %>
            <a href="/blogs?tag=<%= tag %>" class="px-2.5 py-1 bg-slate-100 dark:bg-slate-800 text-xs font-semibold text-slate-600 dark:text-slate-400 rounded-lg hover:bg-slate-200">#<%= tag %></a>
          <% }) %>
        </div>
      </div>

      <!-- Cover Image -->
      <% if (blog.coverImage) { %>
        <div class="rounded-2xl overflow-hidden aspect-video bg-slate-100 dark:bg-slate-950 max-h-[400px] w-full border border-slate-100 dark:border-slate-800">
          <img src="<%= blog.coverImage %>" alt="<%= blog.title %>" class="w-full h-full object-cover">
        </div>
      <% } %>

      <!-- Dynamic Content area -->
      <div class="prose prose-sm sm:prose-base dark:prose-invert max-w-none text-slate-700 dark:text-slate-300 leading-relaxed font-normal select-text">
        <%- blog.content %>
      </div>

    </article>

    <!-- Related Blogs Section -->
    <% if (relatedBlogs && relatedBlogs.length > 0) { %>
      <div class="mt-16 space-y-6">
        <h3 class="font-heading font-extrabold text-xl text-slate-900 dark:text-white border-b border-slate-200 dark:border-slate-800 pb-3">Related Articles</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <% relatedBlogs.forEach(rel => { %>
            <div class="bg-white dark:bg-slate-900 p-5 rounded-2xl border border-slate-100 dark:border-slate-800/80 flex flex-col justify-between hover:shadow-sm transition-shadow h-full">
              <div>
                <span class="text-[9px] text-slate-400 font-bold"><%= new Date(rel.createdAt).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) %></span>
                <h4 class="font-heading font-bold text-sm text-slate-800 dark:text-white mt-1 hover:text-blue-600 transition-colors line-clamp-2">
                  <a href="/blogs/<%= rel.slug %>"><%= rel.title %></a>
                </h4>
              </div>
              <a href="/blogs/<%= rel.slug %>" class="text-blue-600 dark:text-blue-400 hover:text-blue-700 font-bold text-[10px] mt-4 flex items-center transition-colors">
                Read Now
                <i class="fas fa-chevron-right ml-1 text-[8px]"></i>
              </a>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

  </div>
</section>

<%- include('../partials/footer') %>
