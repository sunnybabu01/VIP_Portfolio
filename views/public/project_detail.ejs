<%- include('../partials/header') %>

<section class="py-16 sm:py-24 bg-slate-50 dark:bg-slate-950 transition-colors duration-300 relative min-h-[80vh] flex items-center">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    
    <!-- Breadcrumb back link -->
    <a href="/#projects" class="inline-flex items-center text-xs font-bold text-slate-500 hover:text-blue-600 transition-colors mb-8">
      <i class="fas fa-chevron-left mr-2 text-[9px]"></i>
      Back to Projects
    </a>

    <!-- Detail Box -->
    <div class="bg-white dark:bg-slate-900 rounded-3xl overflow-hidden border border-slate-200/50 dark:border-slate-800/80 shadow-xl p-6 sm:p-10 space-y-8">
      
      <!-- Heading -->
      <div>
        <span class="inline-block px-3 py-1 rounded-full text-[10px] font-bold bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-300 uppercase tracking-wider">
          <%= project.category %>
        </span>
        <h1 class="font-heading font-extrabold text-2xl sm:text-4xl text-slate-900 dark:text-white mt-3 leading-tight"><%= project.title %></h1>
        <p class="text-xs text-slate-400 mt-2 flex items-center">
          <i class="far fa-eye mr-1.5"></i>
          <%= project.views %> views recorded
        </p>
      </div>

      <!-- Banner image -->
      <% if (project.images && project.images.length > 0) { %>
        <div class="rounded-2xl overflow-hidden aspect-video bg-slate-100 dark:bg-slate-950 max-w-3xl mx-auto border border-slate-100 dark:border-slate-800">
          <img src="<%= project.images[0] %>" alt="<%= project.title %>" class="w-full h-full object-cover">
        </div>
      <% } %>

      <!-- Description narrative -->
      <div class="prose prose-sm dark:prose-invert max-w-none">
        <h3 class="font-heading font-bold text-lg text-slate-800 dark:text-white border-b border-slate-100 dark:border-slate-800/80 pb-2 mb-3">Project Description</h3>
        <p class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed font-normal"><%= project.description %></p>
      </div>

      <!-- Technology stack list -->
      <div>
        <h4 class="font-heading font-bold text-xs uppercase tracking-wider text-slate-400">Technologies Used</h4>
        <div class="flex flex-wrap gap-2 mt-2.5">
          <% project.technologies.forEach(tech => { %>
            <span class="px-3 py-1 bg-slate-50 dark:bg-slate-950 border border-slate-200/50 dark:border-slate-800/80 text-xs font-semibold text-slate-700 dark:text-slate-300 rounded-lg">
              <%= tech %>
            </span>
          <% }) %>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex flex-col sm:flex-row items-center justify-end gap-3 border-t border-slate-100 dark:border-slate-800/80 pt-8 mt-8">
        <% if (project.githubLink) { %>
          <a href="<%= project.githubLink %>" target="_blank" class="w-full sm:w-auto px-6 py-3 border border-slate-200 dark:border-slate-800 text-slate-700 dark:text-slate-300 font-bold text-xs rounded-xl hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors flex items-center justify-center">
            <i class="fab fa-github mr-2.5 text-sm"></i> View Repository
          </a>
        <% } %>
        <% if (project.liveLink) { %>
          <a href="<%= project.liveLink %>" target="_blank" class="w-full sm:w-auto px-7 py-3 bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs rounded-xl transition-colors flex items-center justify-center shadow-lg shadow-blue-500/10">
            <i class="fas fa-external-link-alt mr-2.5 text-[10px]"></i> Launch Demo
          </a>
        <% } %>
      </div>

    </div>

  </div>
</section>

<%- include('../partials/footer') %>
