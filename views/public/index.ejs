            <div>
              <label for="contact-email" class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-1.5">Your Email</label>
              <input type="email" id="contact-email" placeholder="john@example.com" class="w-full text-sm px-4 py-3 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500" required>
            </div>
          </div>

          <div>
            <label for="contact-subject" class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-1.5">Subject</label>
            <input type="text" id="contact-subject" placeholder="Project collaboration proposal..." class="w-full text-sm px-4 py-3 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>

          <div>
            <label for="contact-message" class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-1.5">Your Message</label>
            <textarea id="contact-message" rows="5" placeholder="Hi Sunny, I'd love to chat about a job opportunity..." class="w-full text-sm px-4 py-3 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500" required></textarea>
          </div>

          <button type="submit" class="w-full py-3.5 bg-blue-600 hover:bg-blue-700 text-white font-bold text-sm rounded-xl shadow-lg shadow-blue-500/10 active:scale-95 transition-all duration-200 flex items-center justify-center">
            <i class="fas fa-paper-plane mr-2.5"></i>
            Send Message
          </button>
        </form>
      </div>

    </div>
  </div>
</section>

<!-- Global Message Success & Error toasts -->
<div id="contact-success-toast" class="hidden fixed bottom-6 left-6 z-50 glass px-6 py-4 rounded-2xl shadow-2xl border border-green-500/30 flex items-center space-x-3.5 animate-slide-in-right">
  <div class="w-8 h-8 bg-green-100 dark:bg-green-950 text-green-600 dark:text-green-400 flex items-center justify-center rounded-full"><i class="fas fa-check"></i></div>
  <div>
    <h5 class="text-sm font-extrabold font-heading text-slate-800 dark:text-white">Message Dispatched!</h5>
    <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">Your inquiry is logged and email alert sent successfully.</p>
  </div>
</div>

<div id="contact-error-toast" class="hidden fixed bottom-6 left-6 z-50 glass px-6 py-4 rounded-2xl shadow-2xl border border-red-500/30 flex items-center space-x-3.5 animate-slide-in-right">
  <div class="w-8 h-8 bg-red-100 dark:bg-red-950 text-red-600 dark:text-red-400 flex items-center justify-center rounded-full"><i class="fas fa-times"></i></div>
  <div>
    <h5 class="text-sm font-extrabold font-heading text-slate-800 dark:text-white">Dispatch Failed!</h5>
    <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5" id="contact-error-text">Failed to save message to database.</p>
  </div>
</div>

