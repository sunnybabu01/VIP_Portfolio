<!-- TESTIMONIALS SECTION -->
<section id="testimonials" class="py-24 bg-white dark:bg-slate-900 transition-colors duration-300 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Heading -->
    <div class="text-center max-w-3xl mx-auto mb-16 reveal">
      <span class="text-xs font-bold uppercase tracking-wider text-blue-600 dark:text-blue-400">References</span>
      <h2 class="font-heading font-extrabold text-3xl sm:text-5xl mt-2 text-slate-900 dark:text-white">Recommendations & Testimonials</h2>
      <div class="w-16 h-1.5 bg-blue-600 mx-auto mt-4 rounded-full"></div>
    </div>

    <!-- Recommendations slider carousel -->
    <div class="max-w-3xl mx-auto reveal">
      <% if (testimonials && testimonials.length > 0) { %>
        <div class="relative overflow-hidden bg-slate-50 dark:bg-slate-950 border border-slate-200/50 dark:border-slate-800/80 p-8 sm:p-12 rounded-3xl text-center">
          
          <!-- Large quote symbol -->
          <i class="fas fa-quote-right text-5xl text-blue-500/10 dark:text-blue-500/5 absolute top-6 right-6"></i>

          <!-- Slides wrapper -->
          <div class="space-y-6">
            <% testimonials.forEach((t, index) => { %>
              <div class="testimonial-slide <%= index === 0 ? 'block' : 'hidden' %>" id="slide-<%= index %>">
                <p class="text-sm sm:text-base text-slate-600 dark:text-slate-300 leading-relaxed font-normal italic">
                  "<%= t.feedback %>"
                </p>
                <div class="flex items-center justify-center mt-6 space-x-3.5">
                  <div class="w-10 h-10 rounded-full bg-slate-200 overflow-hidden">
                    <% if (t.avatar) { %>
                      <img src="<%= t.avatar %>" alt="<%= t.clientName %>" class="w-full h-full object-cover">
                    <% } else { %>
                      <div class="w-full h-full flex items-center justify-center bg-blue-100 text-blue-600 text-xs font-bold"><%= t.clientName.substring(0,2) %></div>
                    <% } %>
                  </div>
                  <div class="text-left leading-none">
                    <h4 class="font-heading font-bold text-sm text-slate-800 dark:text-white"><%= t.clientName %></h4>
                    <span class="text-[10px] text-slate-400 font-medium mt-1 block"><%= t.designation %></span>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>

          <!-- Carousel Dots navigation -->
          <% if (testimonials.length > 1) { %>
            <div class="flex justify-center space-x-2 mt-8">
              <% testimonials.forEach((t, index) => { %>
                <button onclick="showSlide(<%= index %>)" class="w-2.5 h-2.5 rounded-full transition-all duration-300 <%= index === 0 ? 'bg-blue-600 w-5' : 'bg-slate-300 dark:bg-slate-700' %>" id="dot-<%= index %>"></button>
              <% }) %>
            </div>
            
            <script>
              let currentSlideIdx = 0;
              const slidesCount = <%= testimonials.length %>;
              
              function showSlide(idx) {
                for (let i = 0; i < slidesCount; i++) {
                  const slide = document.getElementById(`slide-${i}`);
                  const dot = document.getElementById(`dot-${i}`);
                  if (slide && dot) {
                    if (i === idx) {
                      slide.classList.remove('hidden');
                      slide.classList.add('block');
                      dot.classList.add('bg-blue-600', 'w-5');
                      dot.classList.remove('bg-slate-300', 'dark:bg-slate-700');
                    } else {
                      slide.classList.remove('block');
                      slide.classList.add('hidden');
                      dot.classList.remove('bg-blue-600', 'w-5');
                      dot.classList.add('bg-slate-300', 'dark:bg-slate-700');
                    }
                  }
                }
                currentSlideIdx = idx;
              }

              // Auto play carousel (every 6 seconds)
              setInterval(() => {
                let next = (currentSlideIdx + 1) % slidesCount;
                showSlide(next);
              }, 6000);
            </script>
          <% } %>

        </div>
      <% } else { %>
        <p class="text-center text-slate-500 font-normal">No client recommendations recorded yet.</p>
      <% } %>
    </div>

    <!-- Feedback button -->
    <div class="text-center mt-12 reveal">
      <button onclick="openFeedbackModal()" class="inline-flex items-center px-6 py-3 rounded-full bg-blue-600 hover:bg-blue-700 text-white font-bold text-sm shadow-lg shadow-blue-500/10 active:scale-95 transition-all">
        <i class="fas fa-pen-fancy mr-2.5"></i> Write a Review / Share Feedback
      </button>
    </div>

    <!-- Feedback Submission Modal -->
    <div id="feedback-modal" class="hidden fixed inset-0 z-50 bg-slate-950/70 p-4 sm:p-6 items-center justify-center animate-fade-in" onclick="closeFeedbackModal(event)">
      <div class="bg-white dark:bg-slate-900 max-w-md w-full rounded-3xl border border-slate-200/50 dark:border-slate-800/80 shadow-2xl overflow-hidden flex flex-col" onclick="event.stopPropagation()">
        
        <div class="p-5 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between bg-slate-50/50 dark:bg-slate-950/30">
          <h3 class="font-heading font-extrabold text-base text-slate-900 dark:text-white">Share Your Feedback</h3>
          <button onclick="hideFeedbackModal()" class="text-slate-400 hover:text-slate-600 dark:hover:text-white p-1 rounded-lg"><i class="fas fa-times text-lg"></i></button>
        </div>
        
        <form id="public-feedback-form" class="p-6 space-y-4 text-xs sm:text-sm">
          <div>
            <label for="feedback-name" class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block mb-1">Your Name</label>
            <input type="text" id="feedback-name" placeholder="e.g. Jane Doe" class="w-full p-3 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500" required>
          </div>

          <div>
            <label for="feedback-designation" class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block mb-1">Designation / Role (Optional)</label>
            <input type="text" id="feedback-designation" placeholder="e.g. Project Partner or Tech Lead" class="w-full p-3 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500">
          </div>

          <div>
            <label for="feedback-text" class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block mb-1">Your Feedback</label>
            <textarea id="feedback-text" rows="4" placeholder="Share your experience working with Sunny..." class="w-full p-3 bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500" required></textarea>
          </div>

          <div class="flex items-center justify-end space-x-3 pt-4 border-t border-slate-100 dark:border-slate-800/80">
            <button type="button" onclick="hideFeedbackModal()" class="px-4 py-2 border border-slate-200 dark:border-slate-800 text-slate-700 dark:text-slate-300 font-bold text-xs rounded-xl hover:bg-slate-50 dark:hover:bg-slate-800">Cancel</button>
            <button type="submit" class="px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs rounded-xl shadow-md flex items-center transition-colors">
              Submit Feedback
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Feedback script helper -->
    <script>
      function openFeedbackModal() {
        const modal = document.getElementById('feedback-modal');
        if (modal) {
          modal.classList.remove('hidden');
          modal.classList.add('flex');
          document.body.style.overflow = 'hidden';
        }
      }

      function hideFeedbackModal() {
        const modal = document.getElementById('feedback-modal');
        if (modal) {
          modal.classList.remove('flex');
          modal.classList.add('hidden');
          document.body.style.overflow = 'auto';
        }
      }

      function closeFeedbackModal(event) {
        hideFeedbackModal();
      }

      document.getElementById('public-feedback-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const submitBtn = e.target.querySelector('button[type="submit"]');
        const originalText = submitBtn.innerHTML;
        
        const clientName = document.getElementById('feedback-name').value;
        const designation = document.getElementById('feedback-designation').value;
        const feedback = document.getElementById('feedback-text').value;

        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1.5"></i> Submitting...';

        try {
          const response = await fetch('/feedback', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ clientName, designation, feedback })
          });
          
          const data = await response.json();
          if (data.success) {
            alert(data.message);
            e.target.reset();
            hideFeedbackModal();
          } else {
            throw new Error(data.message || 'Submission failed');
          }
        } catch (error) {
          alert('Error: ' + error.message);
        } finally {
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalText;
        }
      });
    </script>

  </div>
</section>

