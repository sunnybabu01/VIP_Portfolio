<%- include('../partials/header') %>

<section class="py-16 sm:py-24 bg-slate-50 dark:bg-slate-950 transition-colors duration-300 relative min-h-[85vh]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Heading -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-xs font-bold uppercase tracking-wider text-blue-600 dark:text-blue-400">Knowledge Base</span>
      <h1 class="font-heading font-extrabold text-3xl sm:text-5xl mt-2 text-slate-900 dark:text-white">Technical Blog Articles</h1>
      <div class="w-16 h-1.5 bg-blue-600 mx-auto mt-4 rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- Left sidebar tags filtering panel -->
      <div class="lg:col-span-3 space-y-6 lg:sticky lg:top-24">
        <!-- Search bar -->
        <div class="glass p-5 rounded-2xl border border-slate-200/50 dark:border-slate-800/50">
          <h4 class="font-heading font-bold text-sm text-slate-800 dark:text-white mb-3">Search Articles</h4>
          <form action="/blogs" method="GET" class="relative">
            <input type="text" name="search" value="<%= searchQuery %>" placeholder="Type and hit enter..." class="w-full text-xs pl-3 pr-8 py-2.5 rounded-lg bg-slate-100 dark:bg-slate-950 text-slate-800 dark:text-slate-100 border border-slate-200 dark:border-slate-800 focus:outline-none focus:ring-1 focus:ring-blue-500">
            <button type="submit" class="absolute right-2.5 top-2.5 text-slate-400"><i class="fas fa-search text-sm"></i></button>
          </form>
        </div>

        <!-- Tag chips panel -->
        <div class="glass p-5 rounded-2xl border border-slate-200/50 dark:border-slate-800/50">
          <h4 class="font-heading font-bold text-sm text-slate-800 dark:text-white mb-3">Tags Index</h4>
          <div class="flex flex-wrap gap-2">
            <a href="/blogs" class="px-2.5 py-1 text-[10px] font-bold rounded-md transition-colors <%= !selectedTag ? 'bg-blue-600 text-white' : 'bg-slate-100 dark:bg-slate-850 text-slate-600 dark:text-slate-400 hover:bg-slate-200' %>">
              #All
            </a>
            <% tags.forEach(tag => { %>
              <a href="/blogs?tag=<%= tag %>" class="px-2.5 py-1 text-[10px] font-bold rounded-md transition-colors <%= selectedTag === tag ? 'bg-blue-600 text-white' : 'bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 hover:bg-slate-250 dark:hover:bg-slate-700' %>">
                #<%= tag %>
              </a>
            <% }) %>
          </div>
        </div>
      </div>

      <!-- Blogs Main Grid -->
      <div class="lg:col-span-9">
        
        <!-- Search indicator -->
        <% if (searchQuery || selectedTag) { %>
          <div class="flex items-center justify-between mb-8 bg-blue-50/50 dark:bg-blue-950/20 px-5 py-3.5 rounded-xl border border-blue-200/50 dark:border-blue-800/40">
            <span class="text-xs font-semibold text-slate-600 dark:text-slate-300">
              Showing filter results for: 
              <%= searchQuery ? `Search: "${searchQuery}"` : '' %> 
              <%= selectedTag ? `Tag: "#${selectedTag}"` : '' %>
            </span>
            <a href="/blogs" class="text-xs font-bold text-blue-600 dark:text-blue-400 hover:underline">Clear Filters</a>
          </div>
        <% } %>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <% if (blogs && blogs.length > 0) { %>
            <% blogs.forEach(blog => { %>
              <!-- Blog Card -->
              <div class="bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800/80 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow flex flex-col h-full">
                
                <div class="aspect-video bg-slate-200 dark:bg-slate-950 overflow-hidden relative flex-shrink-0">
                  <% if (blog.coverImage) { %>
                    <img src="<%= blog.coverImage %>" alt="<%= blog.title %>" class="w-full h-full object-cover">
                  <% } else { %>
                    <div class="w-full h-full bg-gradient-to-tr from-blue-100 to-purple-100 dark:from-slate-950 dark:to-slate-800 flex items-center justify-center">
                      <i class="fas fa-file-invoice text-4xl text-blue-500/20"></i>
                    </div>
                  <% } %>
                </div>

                <div class="p-6 flex-grow flex flex-col justify-between">
                  <div>
                    <span class="text-[10px] text-slate-400 font-bold"><%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                    <h3 class="font-heading font-bold text-base text-slate-800 dark:text-white mt-1.5 hover:text-blue-600 transition-colors leading-tight">
                      <a href="/blogs/<%= blog.slug %>"><%= blog.title %></a>
                    </h3>
                    
                    <div class="flex flex-wrap gap-1.5 mt-3">
                      <% blog.tags.forEach(tag => { %>
                        <span class="px-2 py-0.5 bg-slate-100 dark:bg-slate-800 text-[10px] text-slate-500 dark:text-slate-400 font-semibold rounded">#<%= tag %></span>
                      <% }) %>
                    </div>
                  </div>

                  <a href="/blogs/<%= blog.slug %>" class="text-blue-600 dark:text-blue-400 hover:text-blue-750 font-bold text-xs mt-6 flex items-center transition-colors">
                    Read Article
                    <i class="fas fa-chevron-right ml-1 text-[9px]"></i>
                  </a>
                </div>

              </div>
            <% }) %>
          <% } else { %>
            <div class="col-span-full text-center py-12 bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800/80">
              <i class="fas fa-folder-open text-4xl text-slate-300 dark:text-slate-700 mb-3 block"></i>
              <p class="text-sm text-slate-500 font-normal">No articles matched your filter queries.</p>
            </div>
          <% } %>
        </div>

      </div>

    </div>

  </div>
</section>

<%- include('../partials/footer') %>
