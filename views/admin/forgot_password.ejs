<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password | Portfolio CMS</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class'
    }
  </script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/png" href="/images/favicon.png?v=1.1">
</head>
<body class="h-full bg-slate-50 dark:bg-slate-950 text-slate-800 dark:text-slate-100 transition-colors duration-300 flex items-center justify-center relative overflow-hidden">

  <!-- Glowing blobs background -->
  <div class="absolute top-1/4 left-1/4 w-80 h-80 rounded-full bg-blue-500/10 dark:bg-blue-500/5 glow-circle"></div>
  <div class="absolute bottom-1/4 right-1/4 w-80 h-80 rounded-full bg-purple-500/10 dark:bg-purple-500/5 glow-circle"></div>

  <!-- Container -->
  <div class="max-w-md w-full px-6 z-10">
    <div class="glass dark:glass p-8 sm:p-10 rounded-3xl shadow-2xl relative border border-slate-200/50 dark:border-slate-800/50 space-y-8">
      
      <!-- Heading -->
      <div class="text-center">
        <h1 class="font-heading font-extrabold text-2xl text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-purple-600 dark:from-blue-400 dark:to-purple-400">Recover Credentials</h1>
        <p class="text-xs text-slate-400 mt-2">Enter your email and we'll send a password recovery link.</p>
      </div>

      <!-- Action Alerts -->
      <div id="alert-box" class="hidden text-xs px-4 py-3.5 rounded-xl border animate-fade-in"></div>

      <!-- Form -->
      <form id="forgot-form" class="space-y-5">
        <div>
          <label for="email" class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-1.5">Registered Email</label>
          <input type="email" id="email" placeholder="sunny824118@gmail.com" class="w-full text-sm px-4 py-3 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500" required>
        </div>

        <button type="submit" class="w-full py-3.5 bg-blue-600 hover:bg-blue-700 text-white font-bold text-sm rounded-xl shadow-lg active:scale-95 transition-all duration-200 flex items-center justify-center">
          Send Recovery Link
        </button>
      </form>

      <!-- Back Link -->
      <div class="text-center pt-2">
        <a href="/admin/login" class="text-xs font-bold text-slate-500 hover:text-blue-600 transition-colors">
          <i class="fas fa-arrow-left mr-1.5"></i> Back to Login
        </a>
      </div>

    </div>
  </div>

  <script>
    // Sync dark/light theme
    const currentTheme = localStorage.getItem('color-theme') || 
      (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    if (currentTheme === 'dark') {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }

    const forgotForm = document.getElementById('forgot-form');
    const alertBox = document.getElementById('alert-box');
    const submitBtn = forgotForm.querySelector('button[type="submit"]');

    forgotForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const payload = { email: document.getElementById('email').value };

      submitBtn.disabled = true;
      submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Sending...';
      alertBox.classList.add('hidden');

      try {
        const res = await fetch('/admin/forgot-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const data = await res.json();

        if (data.success) {
          alertBox.className = 'text-xs px-4 py-3.5 rounded-xl border border-green-200 bg-green-50 text-green-600 dark:bg-green-950/20 dark:border-green-900/50 dark:text-green-400 block';
          alertBox.textContent = data.message;
          forgotForm.reset();
          submitBtn.disabled = false;
          submitBtn.innerHTML = 'Send Recovery Link';
        } else {
          throw new Error(data.message || 'Operation failed');
        }
      } catch (err) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = 'Send Recovery Link';
        alertBox.className = 'text-xs px-4 py-3.5 rounded-xl border border-red-200 bg-red-50 text-red-600 dark:bg-red-950/20 dark:border-red-900/50 dark:text-red-400 block';
        alertBox.textContent = err.message;
      }
    });
  </script>
</body>
</html>
