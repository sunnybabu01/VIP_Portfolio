<%- include('../partials/admin_header') %>

<div class="space-y-8">
  
  <!-- Page Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="font-heading font-extrabold text-2xl sm:text-3xl text-gray-900 dark:text-white">Blog Manager</h1>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Write new technical articles, manage categories/tags, and edit blog posts databases.</p>
    </div>
    
    <!-- Add Blog Button -->
    <button onclick="toggleModal('add-blog-modal')" class="inline-flex items-center px-4 py-2.5 text-xs font-bold text-white bg-blue-600 rounded-xl hover:bg-blue-700 shadow-md shadow-blue-500/10 transition-all">
      <i class="fas fa-plus mr-2"></i> Write Blog
    </button>
  </div>

  <!-- Blogs list Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% if (blogs && blogs.length > 0) { %>
      <% blogs.forEach(blog => { %>
        <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800/80 rounded-2xl overflow-hidden shadow-sm flex flex-col justify-between">
          
          <!-- Banner -->
          <div class="aspect-video bg-gray-50 dark:bg-gray-950 overflow-hidden relative flex-shrink-0">
            <% if (blog.coverImage) { %>
              <img src="<%= blog.coverImage %>" alt="<%= blog.title %>" class="w-full h-full object-cover">
            <% } else { %>
              <div class="w-full h-full flex items-center justify-center text-gray-400">
                <i class="fas fa-file-invoice text-3xl opacity-30"></i>
              </div>
            <% } %>
          </div>

          <!-- Body details -->
          <div class="p-5 flex-grow flex flex-col justify-between space-y-4">
            <div>
              <span class="text-[9px] text-gray-400 font-bold block"><%= new Date(blog.createdAt).toLocaleDateString() %></span>
              <h3 class="font-heading font-bold text-sm text-gray-900 dark:text-white mt-1 hover:text-blue-600 leading-snug"><%= blog.title %></h3>
              
              <!-- tags -->
              <div class="flex flex-wrap gap-1 mt-3">
                <% blog.tags.forEach(tag => { %>
                  <span class="px-2 py-0.5 bg-gray-50 dark:bg-gray-800 text-[9px] text-gray-500 dark:text-gray-400 font-semibold rounded">#<%= tag %></span>
                <% }) %>
              </div>
            </div>

            <!-- actions -->
            <div class="flex items-center justify-end border-t border-gray-100 dark:border-gray-800/80 pt-4 mt-6">
              <div class="flex space-x-2">
                <a href="/blogs/<%= blog.slug %>" target="_blank" class="p-2 text-gray-400 hover:text-blue-600 rounded-xl" title="View Blog"><i class="fas fa-eye text-xs"></i></a>
                <form action="/admin/blogs/<%= blog._id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this blog post?')" class="inline">
                  <button type="submit" class="p-2 text-red-500 hover:bg-red-50 dark:hover:bg-red-950/20 rounded-xl" title="Delete Blog"><i class="fas fa-trash-can"></i></button>
                </form>
              </div>
            </div>
          </div>

        </div>
      <% }) %>
    <% } else { %>
      <div class="col-span-full text-center py-16 bg-white dark:bg-gray-900 rounded-3xl border border-gray-200 dark:border-gray-800/80">
        <i class="fas fa-pen-nib text-4xl text-gray-300 dark:text-gray-700 mb-3 block animate-pulse"></i>
        <p class="text-sm text-gray-500">No blog posts drafted yet. Click "Write Blog" to begin writing.</p>
      </div>
    <% } %>
  </div>

</div>

<!-- ==========================================
# MODAL: ADD BLOG
========================================== -->
<div id="add-blog-modal" class="hidden fixed inset-0 z-50 bg-gray-950/60 p-4 items-center justify-center animate-fade-in">
  <div class="bg-white dark:bg-gray-900 max-w-2xl w-full rounded-2xl border border-gray-200 dark:border-gray-800 shadow-2xl overflow-hidden flex flex-col max-h-[90vh]">
    <div class="p-5 border-b border-gray-100 dark:border-gray-800 flex items-center justify-between bg-gray-50 dark:bg-gray-950/30">
      <h3 class="font-heading font-extrabold text-sm sm:text-base text-gray-800 dark:text-white">Draft Blog Article</h3>
      <button onclick="toggleModal('add-blog-modal')" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times text-lg"></i></button>
    </div>
    
    <form action="/admin/blogs" method="POST" enctype="multipart/form-data" class="p-6 space-y-4 overflow-y-auto text-xs sm:text-sm">
      <div>
        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Blog Article Title</label>
        <input type="text" name="title" placeholder="e.g. My SIH Crypto detection pathway journey..." class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-850 rounded-xl" required>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Tags (Comma separated list)</label>
          <input type="text" name="tags" placeholder="e.g. Node.js, AI, SIH" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-855 rounded-xl">
        </div>
        <div>
          <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Cover Image</label>
          <input type="file" name="coverImage" accept="image/*" class="w-full text-xs border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-950 rounded-xl p-2">
        </div>
      </div>

      <div>
        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Blog Content (HTML tags supported)</label>
        <textarea name="content" rows="8" placeholder="<p>Write your detailed article paragraphs here...</p>" class="w-full p-3 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-855 rounded-xl font-mono text-[11px]" required></textarea>
      </div>

      <div class="flex items-center justify-end space-x-3 pt-4 border-t border-gray-100 dark:border-gray-850">
        <button type="button" onclick="toggleModal('add-blog-modal')" class="px-4 py-2 border border-gray-200 dark:border-gray-800 text-gray-700 dark:text-gray-300 font-bold text-xs rounded-xl hover:bg-gray-50">Cancel</button>
        <button type="submit" class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs rounded-xl shadow-md">Publish Post</button>
      </div>
    </form>
  </div>
</div>

<script>
  function toggleModal(id) {
    const modal = document.getElementById(id);
    modal.classList.toggle('hidden');
    modal.classList.toggle('flex');
  }
</script>

<%- include('../partials/admin_footer') %>
