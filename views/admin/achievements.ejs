<%- include('../partials/admin_header') %>

<div class="space-y-8">
  
  <!-- Page Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="font-heading font-extrabold text-2xl sm:text-3xl text-gray-900 dark:text-white">Honors & Achievements</h1>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Record hackathon outcomes, academic accomplishments, and rankings milestones.</p>
    </div>
    
    <!-- Add Achievement Button -->
    <button onclick="toggleModal('add-achievement-modal')" class="inline-flex items-center px-4 py-2.5 text-xs font-bold text-white bg-blue-600 rounded-xl hover:bg-blue-700 shadow-md shadow-blue-500/10 transition-all">
      <i class="fas fa-plus mr-2"></i> Add Achievement
    </button>
  </div>

  <!-- Achievements list table -->
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800/80 rounded-3xl overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
      <table class="w-full text-left text-xs border-collapse">
        <thead class="bg-gray-50 dark:bg-gray-950 text-gray-400 uppercase tracking-wider font-bold border-b border-gray-150 dark:border-gray-800">
          <tr>
            <th class="px-6 py-4">Title & details</th>
            <th class="px-6 py-4">Category</th>
            <th class="px-6 py-4">Date Achieved</th>
            <th class="px-6 py-4 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-800/80 text-gray-700 dark:text-gray-300">
          <% if (achievements && achievements.length > 0) { %>
            <% achievements.forEach(ach => { %>
              <tr class="hover:bg-gray-50/50 dark:hover:bg-gray-950/20 transition-colors">
                <td class="px-6 py-4 font-bold text-gray-900 dark:text-white max-w-xs sm:max-w-md">
                  <div><%= ach.title %></div>
                  <div class="text-[10px] text-gray-400 font-semibold mt-1 leading-relaxed"><%= ach.description %></div>
                </td>
                <td class="px-6 py-4 font-semibold text-slate-500 dark:text-slate-400"><%= ach.category %></td>
                <td class="px-6 py-4 font-semibold"><%= new Date(ach.date).toLocaleDateString() %></td>
                <td class="px-6 py-4 text-right">
                  <form action="/admin/achievements/<%= ach._id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this achievement?')" class="inline">
                    <button type="submit" class="p-2 text-red-500 hover:bg-red-50 dark:hover:bg-red-950/20 rounded-xl" title="Delete Achievement">
                      <i class="fas fa-trash-can"></i>
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="4" class="px-6 py-12 text-center text-gray-400">
                <i class="fas fa-trophy text-3xl mb-3 block"></i>
                No achievements added yet. Click "Add Achievement" to begin.
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

</div>

<!-- ==========================================
# MODAL: ADD ACHIEVEMENT
========================================== -->
<div id="add-achievement-modal" class="hidden fixed inset-0 z-50 bg-gray-950/60 p-4 items-center justify-center animate-fade-in">
  <div class="bg-white dark:bg-gray-900 max-w-md w-full rounded-2xl border border-gray-200 dark:border-gray-800 shadow-2xl overflow-hidden flex flex-col">
    <div class="p-5 border-b border-gray-100 dark:border-gray-800 flex items-center justify-between bg-gray-50 dark:bg-gray-950/30">
      <h3 class="font-heading font-extrabold text-sm sm:text-base text-gray-800 dark:text-white">Add Achievement</h3>
      <button onclick="toggleModal('add-achievement-modal')" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times text-lg"></i></button>
    </div>
    
    <form action="/admin/achievements" method="POST" class="p-6 space-y-4 text-xs sm:text-sm">
      <div>
        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Achievement Title</label>
        <input type="text" name="title" placeholder="e.g. SIH Grand Finalist" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-850 rounded-xl" required>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Category Category</label>
          <select name="category" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-850 rounded-xl" required>
            <option value="Hackathon">Hackathon</option>
            <option value="Competition">Competition</option>
            <option value="Certification">Certification</option>
            <option value="Academic">Academic</option>
            <option value="Other">Other</option>
          </select>
        </div>
        <div>
          <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Date Achieved</label>
          <input type="date" name="date" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-855 rounded-xl" required>
        </div>
      </div>

      <div>
        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Short Description</label>
        <textarea name="description" rows="3" placeholder="Briefly describe what was achieved, rankings, etc..." class="w-full p-3 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-855 rounded-xl" required></textarea>
      </div>

      <div class="flex items-center justify-end space-x-3 pt-4 border-t border-gray-100 dark:border-gray-850">
        <button type="button" onclick="toggleModal('add-achievement-modal')" class="px-4 py-2 border border-gray-200 dark:border-gray-800 text-gray-700 dark:text-gray-300 font-bold text-xs rounded-xl hover:bg-gray-50">Cancel</button>
        <button type="submit" class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs rounded-xl shadow-md">Record Achievement</button>
      </div>
    </form>
  </div>
</div>

<script>
  function toggleModal(id) {
    const modal = document.getElementById(id);
    modal.classList.toggle('hidden');
    modal.classList.toggle('flex');
  }
</script>

<%- include('../partials/admin_footer') %>
