<%- include('../partials/admin_header') %>

<div class="space-y-8">
  
  <!-- Page Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="font-heading font-extrabold text-2xl sm:text-3xl text-gray-900 dark:text-white">Technical Skills</h1>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Add, edit, or delete programming languages, database systems, cloud, and tools.</p>
    </div>
    
    <!-- Add Skill Button Trigger -->
    <button onclick="toggleModal('add-skill-modal')" class="inline-flex items-center px-4 py-2.5 text-xs font-bold text-white bg-blue-600 rounded-xl hover:bg-blue-700 shadow-md shadow-blue-500/10 transition-all">
      <i class="fas fa-plus mr-2"></i> Add Skill
    </button>
  </div>

  <!-- Skills Listing Table -->
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800/80 rounded-3xl overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
      <table class="w-full text-left text-xs border-collapse">
        <thead class="bg-gray-50 dark:bg-gray-950 text-gray-400 uppercase tracking-wider font-bold border-b border-gray-150 dark:border-gray-800">
          <tr>
            <th class="px-6 py-4">Skill Icon & Name</th>
            <th class="px-6 py-4">Category</th>
            <th class="px-6 py-4">Proficiency Level</th>
            <th class="px-6 py-4 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-800/80 text-gray-700 dark:text-gray-300">
          <% if (skills && skills.length > 0) { %>
            <% skills.forEach(skill => { %>
              <tr class="hover:bg-gray-50/50 dark:hover:bg-gray-950/20 transition-colors">
                <td class="px-6 py-4 font-bold flex items-center space-x-3.5 text-gray-900 dark:text-white">
                  <div class="w-9 h-9 bg-gray-50 dark:bg-gray-950 rounded-xl flex items-center justify-center border border-gray-100 dark:border-gray-800">
                    <i class="<%= skill.icon || 'fas fa-code' %> text-base text-blue-500"></i>
                  </div>
                  <span><%= skill.name %></span>
                </td>
                <td class="px-6 py-4 font-semibold text-slate-500 dark:text-slate-400"><%= skill.category %></td>
                <td class="px-6 py-4">
                  <div class="flex items-center space-x-3 max-w-[200px]">
                    <div class="flex-grow bg-gray-100 dark:bg-gray-950 rounded-full h-1.5 overflow-hidden">
                      <div class="bg-blue-600 h-1.5 rounded-full" style="width: <%= skill.level %>%"></div>
                    </div>
                    <span class="font-semibold text-blue-600 dark:text-blue-400"><%= skill.level %>%</span>
                  </div>
                </td>
                <td class="px-6 py-4 text-right">
                  <div class="flex items-center justify-end space-x-2.5">
                    <!-- Edit Button -->
                    <button onclick="openEditSkillModal('<%= skill._id %>', '<%= skill.name %>', '<%= skill.category %>', '<%= skill.level %>', '<%= skill.icon %>')" class="p-2 text-blue-500 hover:bg-blue-50 dark:hover:bg-blue-950/20 rounded-xl border border-transparent" title="Edit Skill">
                      <i class="fas fa-edit"></i>
                    </button>
                    <!-- Delete Button Form -->
                    <form action="/admin/skills/<%= skill._id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this skill?')" class="inline">
                      <button type="submit" class="p-2 text-red-500 hover:bg-red-50 dark:hover:bg-red-950/20 rounded-xl border border-transparent" title="Delete Skill">
                        <i class="fas fa-trash-can"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="4" class="px-6 py-12 text-center text-gray-400">
                <i class="fas fa-folder-open text-3xl mb-3 block"></i>
                No technical skills have been recorded yet. Click "Add Skill" to begin.
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

</div>

<!-- ==========================================
# MODAL 1: ADD NEW SKILL
========================================== -->
<div id="add-skill-modal" class="hidden fixed inset-0 z-50 bg-gray-950/60 p-4 items-center justify-center animate-fade-in">
  <div class="bg-white dark:bg-gray-900 max-w-md w-full rounded-2xl border border-gray-200 dark:border-gray-800 shadow-2xl overflow-hidden flex flex-col">
    <!-- Header -->
    <div class="p-5 border-b border-gray-100 dark:border-gray-800 flex items-center justify-between bg-gray-50 dark:bg-gray-950/30">
      <h3 class="font-heading font-extrabold text-sm sm:text-base text-gray-800 dark:text-white">Add New Skill</h3>
      <button onclick="toggleModal('add-skill-modal')" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times text-lg"></i></button>
    </div>
    
    <!-- Form -->
    <form action="/admin/skills" method="POST" class="p-6 space-y-4 text-xs sm:text-sm">
      <div>
        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Skill Name</label>
        <input type="text" name="name" placeholder="e.g. Java" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-800 rounded-xl text-xs" required>
      </div>

      <div>
        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Category Group</label>
        <select name="category" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-800 rounded-xl text-xs" required>
          <option value="Languages">Languages</option>
          <option value="Frontend">Frontend</option>
          <option value="Backend">Backend</option>
          <option value="Database">Database</option>
          <option value="Cloud">Cloud</option>
          <option value="AI/ML">AI/ML</option>
          <option value="Tools">Tools</option>
        </select>
      </div>

      <div>
        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Proficiency Level (1-100)</label>
        <input type="number" name="level" min="1" max="100" placeholder="e.g. 85" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-800 rounded-xl text-xs" required>
      </div>

      <div>
        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Icon FontAwesome Class</label>
        <input type="text" name="icon" placeholder="e.g. fab fa-java text-red-500" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-800 rounded-xl text-xs" required>
      </div>

      <!-- Action Footer -->
      <div class="flex items-center justify-end space-x-3 pt-4 border-t border-gray-100 dark:border-gray-850">
        <button type="button" onclick="toggleModal('add-skill-modal')" class="px-4 py-2 border border-gray-200 dark:border-gray-800 text-gray-700 dark:text-gray-300 font-bold text-xs rounded-xl hover:bg-gray-50">Cancel</button>
        <button type="submit" class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs rounded-xl shadow-md">Add Skill</button>
      </div>
    </form>
  </div>
</div>

<!-- ==========================================
# MODAL 2: EDIT SKILL
========================================== -->
<div id="edit-skill-modal" class="hidden fixed inset-0 z-50 bg-gray-950/60 p-4 items-center justify-center animate-fade-in">
  <div class="bg-white dark:bg-gray-900 max-w-md w-full rounded-2xl border border-gray-200 dark:border-gray-800 shadow-2xl overflow-hidden flex flex-col">
    <!-- Header -->
    <div class="p-5 border-b border-gray-100 dark:border-gray-800 flex items-center justify-between bg-gray-50 dark:bg-gray-950/30">
      <h3 class="font-heading font-extrabold text-sm sm:text-base text-gray-800 dark:text-white">Edit Skill</h3>
      <button onclick="toggleModal('edit-skill-modal')" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times text-lg"></i></button>
    </div>
    
    <!-- Form -->
    <form id="edit-skill-form" action="" method="POST" class="p-6 space-y-4 text-xs sm:text-sm">
      <div>
        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Skill Name</label>
        <input type="text" name="name" id="edit-skill-name" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-800 rounded-xl text-xs" required>
      </div>

      <div>
        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Category Group</label>
        <select name="category" id="edit-skill-category" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-800 rounded-xl text-xs" required>
          <option value="Languages">Languages</option>
          <option value="Frontend">Frontend</option>
          <option value="Backend">Backend</option>
          <option value="Database">Database</option>
          <option value="Cloud">Cloud</option>
          <option value="AI/ML">AI/ML</option>
          <option value="Tools">Tools</option>
        </select>
      </div>

      <div>
        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Proficiency Level (1-100)</label>
        <input type="number" name="level" id="edit-skill-level" min="1" max="100" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-800 rounded-xl text-xs" required>
      </div>

      <div>
        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Icon FontAwesome Class</label>
        <input type="text" name="icon" id="edit-skill-icon" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-800 rounded-xl text-xs" required>
      </div>

      <!-- Action Footer -->
      <div class="flex items-center justify-end space-x-3 pt-4 border-t border-gray-100 dark:border-gray-855">
        <button type="button" onclick="toggleModal('edit-skill-modal')" class="px-4 py-2 border border-gray-200 dark:border-gray-800 text-gray-700 dark:text-gray-300 font-bold text-xs rounded-xl hover:bg-gray-50">Cancel</button>
        <button type="submit" class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs rounded-xl shadow-md">Save Changes</button>
      </div>
    </form>
  </div>
</div>

<script>
  function toggleModal(id) {
    const modal = document.getElementById(id);
    modal.classList.toggle('hidden');
    modal.classList.toggle('flex');
  }

  function openEditSkillModal(id, name, category, level, icon) {
    document.getElementById('edit-skill-name').value = name;
    document.getElementById('edit-skill-category').value = category;
    document.getElementById('edit-skill-level').value = level;
    document.getElementById('edit-skill-icon').value = icon;
    
    // Set form action path dynamically
    document.getElementById('edit-skill-form').setAttribute('action', `/admin/skills/${id}/edit`);
    toggleModal('edit-skill-modal');
  }
</script>

<%- include('../partials/admin_footer') %>
