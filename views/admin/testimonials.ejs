<%- include('../partials/admin_header') %>

<div class="space-y-8">
  
  <!-- Page Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="font-heading font-extrabold text-2xl sm:text-3xl text-gray-900 dark:text-white">Recommendations & Reviews</h1>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Manage peer reviews, professor recommendations, and collaboration comments.</p>
    </div>
    
    <!-- Add Testimonial Button -->
    <button onclick="toggleModal('add-testimonial-modal')" class="inline-flex items-center px-4 py-2.5 text-xs font-bold text-white bg-blue-600 rounded-xl hover:bg-blue-700 shadow-md shadow-blue-500/10 transition-all">
      <i class="fas fa-plus mr-2"></i> Add Review
    </button>
  </div>

  <% 
    const pendingReviews = testimonials.filter(t => !t.isApproved);
    const approvedReviews = testimonials.filter(t => t.isApproved);
  %>

  <!-- Pending Reviews Section -->
  <% if (pendingReviews.length > 0) { %>
    <div class="space-y-4">
      <h2 class="font-heading font-extrabold text-lg text-gray-900 dark:text-white flex items-center">
        <span class="w-2.5 h-2.5 bg-yellow-500 rounded-full mr-2.5 animate-pulse"></span>
        Pending Approvals (<%= pendingReviews.length %>)
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        <% pendingReviews.forEach(t => { %>
          <div class="bg-yellow-50/20 dark:bg-yellow-950/5 border border-yellow-250 dark:border-yellow-900/40 p-6 rounded-2xl shadow-sm relative flex flex-col justify-between">
            <div>
              <p class="text-xs text-gray-500 dark:text-gray-400 font-normal italic leading-relaxed">"<%= t.feedback %>"</p>
            </div>

            <div class="flex items-center justify-between border-t border-gray-150 dark:border-gray-850/80 pt-4 mt-6">
              <div class="flex items-center space-x-3 text-xs leading-none">
                <div class="w-8 h-8 rounded-full overflow-hidden bg-slate-100 flex items-center justify-center font-bold text-blue-600">
                  <% if (t.avatar) { %>
                    <img src="<%= t.avatar %>" alt="<%= t.clientName %>" class="w-full h-full object-cover">
                  <% } else { %>
                    <%= t.clientName.substring(0, 2) %>
                  <% } %>
                </div>
                <div>
                  <h4 class="font-heading font-bold text-gray-900 dark:text-white"><%= t.clientName %></h4>
                  <span class="text-[9px] text-gray-400 font-medium block mt-1"><%= t.designation %></span>
                </div>
              </div>

              <div class="flex items-center space-x-2">
                <!-- Approve Form -->
                <form action="/admin/testimonials/<%= t._id %>/approve" method="POST" class="inline">
                  <button type="submit" class="px-3.5 py-1.5 bg-green-605 hover:bg-green-700 text-white font-bold text-[10px] rounded-lg shadow-sm transition-colors flex items-center">
                    <i class="fas fa-check mr-1.5"></i> Approve
                  </button>
                </form>
                
                <!-- Delete Form -->
                <form action="/admin/testimonials/<%= t._id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to decline and delete this review?')" class="inline">
                  <button type="submit" class="p-2 text-red-500 hover:bg-red-50 dark:hover:bg-red-950/20 rounded-lg" title="Decline and Delete">
                    <i class="fas fa-trash-can text-sm"></i>
                  </button>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
    
    <div class="border-b border-gray-100 dark:border-gray-800/80 my-8 max-w-5xl mx-auto"></div>
  <% } %>

  <!-- Approved Reviews Section -->
  <div class="space-y-4">
    <h2 class="font-heading font-extrabold text-lg text-gray-900 dark:text-white flex items-center">
      <span class="w-2.5 h-2.5 bg-green-500 rounded-full mr-2.5"></span>
      Approved Reviews (<%= approvedReviews.length %>)
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
      <% if (approvedReviews.length > 0) { %>
        <% approvedReviews.forEach(t => { %>
          <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800/80 p-6 rounded-2xl shadow-sm hover:shadow-md transition-shadow relative flex flex-col justify-between">
            <div>
              <p class="text-xs text-gray-500 dark:text-gray-400 font-normal italic leading-relaxed">"<%= t.feedback %>"</p>
            </div>

            <div class="flex items-center justify-between border-t border-gray-100 dark:border-gray-800/80 pt-4 mt-6">
              <div class="flex items-center space-x-3 text-xs leading-none">
                <div class="w-8 h-8 rounded-full overflow-hidden bg-slate-100 flex items-center justify-center font-bold text-blue-600">
                  <% if (t.avatar) { %>
                    <img src="<%= t.avatar %>" alt="<%= t.clientName %>" class="w-full h-full object-cover">
                  <% } else { %>
                    <%= t.clientName.substring(0, 2) %>
                  <% } %>
                </div>
                <div>
                  <h4 class="font-heading font-bold text-gray-900 dark:text-white"><%= t.clientName %></h4>
                  <span class="text-[9px] text-gray-400 font-medium block mt-1"><%= t.designation %></span>
                </div>
              </div>

              <form action="/admin/testimonials/<%= t._id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this recommendation?')" class="inline">
                <button type="submit" class="p-2 text-red-500 hover:bg-red-50 dark:hover:bg-red-950/20 rounded-xl" title="Delete Review">
                  <i class="fas fa-trash-can text-sm"></i>
                </button>
              </form>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-span-full text-center py-16 bg-white dark:bg-gray-900 rounded-3xl border border-gray-200 dark:border-gray-800/80 w-full">
          <i class="fas fa-quote-left text-4xl text-gray-300 dark:text-gray-700 mb-3 block"></i>
          <p class="text-sm text-gray-500">No approved reviews registered yet.</p>
        </div>
      <% } %>
    </div>
  </div>

</div>

<!-- ==========================================
# MODAL: ADD TESTIMONIAL
========================================== -->
<div id="add-testimonial-modal" class="hidden fixed inset-0 z-50 bg-gray-950/60 p-4 items-center justify-center animate-fade-in">
  <div class="bg-white dark:bg-gray-900 max-w-md w-full rounded-2xl border border-gray-200 dark:border-gray-800 shadow-2xl overflow-hidden flex flex-col">
    <div class="p-5 border-b border-gray-100 dark:border-gray-800 flex items-center justify-between bg-gray-50 dark:bg-gray-950/30">
      <h3 class="font-heading font-extrabold text-sm sm:text-base text-gray-800 dark:text-white">Record Recommendation</h3>
      <button onclick="toggleModal('add-testimonial-modal')" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times text-lg"></i></button>
    </div>
    
    <form action="/admin/testimonials" method="POST" enctype="multipart/form-data" class="p-6 space-y-4 text-xs sm:text-sm">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Author Name</label>
          <input type="text" name="clientName" placeholder="e.g. Prof. Kumar" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-850 rounded-xl" required>
        </div>
        <div>
          <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Designation</label>
          <input type="text" name="designation" placeholder="e.g. HOD CSE, SIRT" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-855 rounded-xl" required>
        </div>
      </div>

      <div>
        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Feedback / Quote Text</label>
        <textarea name="feedback" rows="4" placeholder="Sunny is a quick learner..." class="w-full p-3 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-855 rounded-xl" required></textarea>
      </div>

      <div>
        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Author Photo / Avatar</label>
        <input type="file" name="avatar" accept="image/*" class="w-full text-xs border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-950 rounded-xl p-2">
      </div>

      <div class="flex items-center justify-end space-x-3 pt-4 border-t border-gray-100 dark:border-gray-855">
        <button type="button" onclick="toggleModal('add-testimonial-modal')" class="px-4 py-2 border border-gray-200 dark:border-gray-800 text-gray-700 dark:text-gray-300 font-bold text-xs rounded-xl hover:bg-gray-50">Cancel</button>
        <button type="submit" class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs rounded-xl shadow-md">Add Testimonial</button>
      </div>
    </form>
  </div>
</div>

<script>
  function toggleModal(id) {
    const modal = document.getElementById(id);
    modal.classList.toggle('hidden');
    modal.classList.toggle('flex');
  }
</script>

<%- include('../partials/admin_footer') %>
