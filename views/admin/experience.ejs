<%- include('../partials/admin_header') %>

<div class="space-y-8">
  
  <!-- Page Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="font-heading font-extrabold text-2xl sm:text-3xl text-gray-900 dark:text-white">Job & Internships</h1>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Manage professional timeline history, company titles, and list key responsibilities.</p>
    </div>
    
    <!-- Add Experience Button -->
    <button onclick="toggleModal('add-experience-modal')" class="inline-flex items-center px-4 py-2.5 text-xs font-bold text-white bg-blue-600 rounded-xl hover:bg-blue-700 shadow-md shadow-blue-500/10 transition-all">
      <i class="fas fa-plus mr-2"></i> Add Experience
    </button>
  </div>

  <!-- Experience Table/List -->
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800/80 rounded-3xl overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
      <table class="w-full text-left text-xs border-collapse">
        <thead class="bg-gray-50 dark:bg-gray-950 text-gray-400 uppercase tracking-wider font-bold border-b border-gray-150 dark:border-gray-800">
          <tr>
            <th class="px-6 py-4">Role & Company</th>
            <th class="px-6 py-4">Type</th>
            <th class="px-6 py-4">Duration</th>
            <th class="px-6 py-4 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-800/80 text-gray-700 dark:text-gray-300">
          <% if (experiences && experiences.length > 0) { %>
            <% experiences.forEach(exp => { %>
              <tr class="hover:bg-gray-50/50 dark:hover:bg-gray-950/20 transition-colors">
                <td class="px-6 py-4 font-bold text-gray-900 dark:text-white">
                  <div><%= exp.role %></div>
                  <div class="text-[10px] text-gray-400 font-semibold mt-0.5"><%= exp.company %></div>
                </td>
                <td class="px-6 py-4 font-semibold text-slate-500 dark:text-slate-400"><%= exp.type %></td>
                <td class="px-6 py-4 font-semibold"><%= exp.duration %></td>
                <td class="px-6 py-4 text-right">
                  <div class="flex items-center justify-end space-x-2.5">
                    <!-- Edit Button -->
                    <button onclick="openEditExperienceModal('<%= exp._id %>', '<%= exp.role %>', '<%= exp.company %>', '<%= exp.type %>', '<%= exp.duration %>', '<%= exp.description.join(`\\n`) %>', '<%= exp.order %>')" class="p-2 text-blue-500 hover:bg-blue-50 dark:hover:bg-blue-950/20 rounded-xl" title="Edit Experience">
                      <i class="fas fa-edit"></i>
                    </button>
                    <!-- Delete Form -->
                    <form action="/admin/experience/<%= exp._id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this experience timeline?')" class="inline">
                      <button type="submit" class="p-2 text-red-500 hover:bg-red-50 dark:hover:bg-red-950/20 rounded-xl" title="Delete Experience">
                        <i class="fas fa-trash-can"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="4" class="px-6 py-12 text-center text-gray-400">
                <i class="fas fa-briefcase text-3xl mb-3 block"></i>
                No work or internship experiences recorded yet. Click "Add Experience" to begin.
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

</div>

<!-- ==========================================
# MODAL 1: ADD EXPERIENCE
========================================== -->
<div id="add-experience-modal" class="hidden fixed inset-0 z-50 bg-gray-950/60 p-4 items-center justify-center animate-fade-in">
  <div class="bg-white dark:bg-gray-900 max-w-lg w-full rounded-2xl border border-gray-200 dark:border-gray-800 shadow-2xl overflow-hidden flex flex-col">
    <div class="p-5 border-b border-gray-100 dark:border-gray-800 flex items-center justify-between bg-gray-50 dark:bg-gray-950/30">
      <h3 class="font-heading font-extrabold text-sm sm:text-base text-gray-800 dark:text-white">Add New Experience</h3>
      <button onclick="toggleModal('add-experience-modal')" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times text-lg"></i></button>
    </div>
    
    <form action="/admin/experience" method="POST" class="p-6 space-y-4 text-xs sm:text-sm">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Role / Designation</label>
          <input type="text" name="role" placeholder="e.g. Backend Intern" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-850 rounded-xl" required>
        </div>
        <div>
          <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Company / Organization</label>
          <input type="text" name="company" placeholder="e.g. InnovateTech" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-855 rounded-xl" required>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Experience Type</label>
          <select name="type" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-850 rounded-xl">
            <option value="Internship">Internship</option>
            <option value="Full-time">Full-time</option>
          </select>
        </div>
        <div>
          <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Duration Range</label>
          <input type="text" name="duration" placeholder="e.g. Jun 2024 - Present" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-855 rounded-xl" required>
        </div>
        <div>
          <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Order (For sorting)</label>
          <input type="number" name="order" value="1" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-855 rounded-xl" required>
        </div>
      </div>

      <div>
        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Responsibilities (One bullet point per line)</label>
        <textarea name="description" rows="5" placeholder="Built RESTful APIs in Express...&#10;Integrated AWS S3 buckets..." class="w-full p-3 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-855 rounded-xl" required></textarea>
      </div>

      <div class="flex items-center justify-end space-x-3 pt-4 border-t border-gray-100 dark:border-gray-850">
        <button type="button" onclick="toggleModal('add-experience-modal')" class="px-4 py-2 border border-gray-200 dark:border-gray-800 text-gray-700 dark:text-gray-300 font-bold text-xs rounded-xl hover:bg-gray-50">Cancel</button>
        <button type="submit" class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs rounded-xl shadow-md">Add Experience</button>
      </div>
    </form>
  </div>
</div>

<!-- ==========================================
# MODAL 2: EDIT EXPERIENCE
========================================== -->
<div id="edit-experience-modal" class="hidden fixed inset-0 z-50 bg-gray-950/60 p-4 items-center justify-center animate-fade-in">
  <div class="bg-white dark:bg-gray-900 max-w-lg w-full rounded-2xl border border-gray-200 dark:border-gray-800 shadow-2xl overflow-hidden flex flex-col">
    <div class="p-5 border-b border-gray-100 dark:border-gray-800 flex items-center justify-between bg-gray-50 dark:bg-gray-950/30">
      <h3 class="font-heading font-extrabold text-sm sm:text-base text-gray-800 dark:text-white">Edit Experience Details</h3>
      <button onclick="toggleModal('edit-experience-modal')" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times text-lg"></i></button>
    </div>
    
    <form id="edit-experience-form" action="" method="POST" class="p-6 space-y-4 text-xs sm:text-sm">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Role / Designation</label>
          <input type="text" name="role" id="edit-role" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-850 rounded-xl" required>
        </div>
        <div>
          <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Company / Organization</label>
          <input type="text" name="company" id="edit-company" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-855 rounded-xl" required>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Experience Type</label>
          <select name="type" id="edit-type" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-850 rounded-xl">
            <option value="Internship">Internship</option>
            <option value="Full-time">Full-time</option>
          </select>
        </div>
        <div>
          <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Duration Range</label>
          <input type="text" name="duration" id="edit-duration" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-855 rounded-xl" required>
        </div>
        <div>
          <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Order (For sorting)</label>
          <input type="number" name="order" id="edit-order" class="w-full p-2.5 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-855 rounded-xl" required>
        </div>
      </div>

      <div>
        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider block mb-1">Responsibilities (One bullet point per line)</label>
        <textarea name="description" id="edit-description" rows="5" class="w-full p-3 bg-gray-50 dark:bg-gray-950 border border-gray-250 dark:border-gray-855 rounded-xl" required></textarea>
      </div>

      <div class="flex items-center justify-end space-x-3 pt-4 border-t border-gray-100 dark:border-gray-850">
        <button type="button" onclick="toggleModal('edit-experience-modal')" class="px-4 py-2 border border-gray-200 dark:border-gray-800 text-gray-700 dark:text-gray-300 font-bold text-xs rounded-xl hover:bg-gray-50">Cancel</button>
        <button type="submit" class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs rounded-xl shadow-md">Save Changes</button>
      </div>
    </form>
  </div>
</div>

<script>
  function toggleModal(id) {
    const modal = document.getElementById(id);
    modal.classList.toggle('hidden');
    modal.classList.toggle('flex');
  }

  function openEditExperienceModal(id, role, company, type, duration, desc, order) {
    document.getElementById('edit-role').value = role;
    document.getElementById('edit-company').value = company;
    document.getElementById('edit-type').value = type;
    document.getElementById('edit-duration').value = duration;
    document.getElementById('edit-description').value = desc;
    document.getElementById('edit-order').value = order;

    document.getElementById('edit-experience-form').setAttribute('action', `/admin/experience/${id}/edit`);
    toggleModal('edit-experience-modal');
  }
</script>

<%- include('../partials/admin_footer') %>
