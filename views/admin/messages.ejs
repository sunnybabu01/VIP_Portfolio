<%- include('../partials/admin_header') %>

<div class="space-y-8">
  
  <!-- Page Header -->
  <div>
    <h1 class="font-heading font-extrabold text-2xl sm:text-3xl text-gray-900 dark:text-white">Messages Inbox</h1>
    <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Review contact requests submitted by visitors on public pages.</p>
  </div>

  <!-- Messages Table -->
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800/80 rounded-3xl overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
      <table class="w-full text-left text-xs border-collapse">
        <thead class="bg-gray-50 dark:bg-gray-950 text-gray-400 uppercase tracking-wider font-bold border-b border-gray-150 dark:border-gray-800">
          <tr>
            <th class="px-6 py-4">Sender Details</th>
            <th class="px-6 py-4">Subject</th>
            <th class="px-6 py-4">Message Body</th>
            <th class="px-6 py-4 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-800/80 text-gray-700 dark:text-gray-300">
          <% if (messages && messages.length > 0) { %>
            <% messages.forEach(msg => { %>
              <tr class="hover:bg-gray-50/50 dark:hover:bg-gray-950/20 transition-colors <%= msg.isRead ? '' : 'bg-blue-50/10 dark:bg-blue-950/5' %>" id="msg-row-<%= msg._id %>">
                <td class="px-6 py-4 font-bold text-gray-900 dark:text-white">
                  <div class="flex items-center space-x-2">
                    <span><%= msg.name %></span>
                    <% if (!msg.isRead) { %>
                      <span class="w-1.5 h-1.5 bg-blue-600 rounded-full animate-pulse" id="unread-dot-<%= msg._id %>"></span>
                    <% } %>
                  </div>
                  <div class="text-[10px] text-gray-400 font-semibold mt-0.5"><a href="mailto:<%= msg.email %>" class="hover:underline"><%= msg.email %></a></div>
                </td>
                <td class="px-6 py-4 font-semibold text-slate-500 dark:text-slate-400 max-w-[150px] truncate"><%= msg.subject %></td>
                <td class="px-6 py-4 text-xs font-normal max-w-xs sm:max-w-md truncate whitespace-pre-wrap"><%= msg.message %></td>
                <td class="px-6 py-4 text-right">
                  <div class="flex items-center justify-end space-x-2.5">
                    <!-- Read toggle button (AJAX) -->
                    <% if (!msg.isRead) { %>
                      <button onclick="markAsRead('<%= msg._id %>')" id="read-btn-<%= msg._id %>" class="p-2 text-green-500 hover:bg-green-50 dark:hover:bg-green-950/20 rounded-xl" title="Mark as Read">
                        <i class="fas fa-check-circle"></i>
                      </button>
                    <% } %>
                    
                    <!-- Delete Form -->
                    <form action="/admin/messages/<%= msg._id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this message?')" class="inline">
                      <button type="submit" class="p-2 text-red-500 hover:bg-red-50 dark:hover:bg-red-950/20 rounded-xl" title="Delete Message">
                        <i class="fas fa-trash-can"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="4" class="px-6 py-12 text-center text-gray-400">
                <i class="fas fa-envelope-open text-3xl mb-3 block"></i>
                Your inbox is empty. No messages received.
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

</div>

<script>
  async function markAsRead(id) {
    try {
      const res = await fetch(`/admin/messages/${id}/read`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });
      const data = await res.json();

      if (data.success) {
        // Toggle dots & button highlights
        const dot = document.getElementById(`unread-dot-${id}`);
        const btn = document.getElementById(`read-btn-${id}`);
        const row = document.getElementById(`msg-row-${id}`);

        if (dot) dot.remove();
        if (btn) btn.remove();
        if (row) row.classList.remove('bg-blue-50/10', 'dark:bg-blue-950/5');
      }
    } catch (e) {
      console.error('Mark read AJAX transaction failed:', e);
    }
  }
</script>

<%- include('../partials/admin_footer') %>
